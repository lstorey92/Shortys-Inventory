generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum IntegrationSource {
  TOAST
  XTRACHEF
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

enum CountSessionStatus {
  OPEN
  LOCKED
}

model Organization {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  locations Location[]
  users     User[]
}

model Location {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  externalRef    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemConfigs    LocationItem[]
  countSessions  CountSession[]

  @@index([organizationId])
  @@unique([organizationId, name])
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  email          String       @unique
  fullName       String
  role           Role
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  countSessions  CountSession[] @relation("CountSessionCreatedBy")

  @@index([organizationId])
}

model UnitOfMeasure {
  id        String    @id @default(cuid())
  name      String    @unique
  shortCode String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  items     InventoryItem[] @relation("InventoryBaseUnit")
}

model InventoryItem {
  id                 String         @id @default(cuid())
  organizationId     String
  name               String
  sku                String?
  baseUnitId         String
  active             Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  baseUnit           UnitOfMeasure  @relation("InventoryBaseUnit", fields: [baseUnitId], references: [id])
  locationConfigs    LocationItem[]
  externalMappings   ExternalMapping[]
  countEntries       CountEntry[]
  unitConversions    UnitConversion[]

  @@index([organizationId])
  @@unique([organizationId, name])
}

model UnitConversion {
  id             String    @id @default(cuid())
  itemId         String
  fromUnitId     String
  toUnitId       String
  factor         Decimal   @db.Decimal(12, 4)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  item           InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, fromUnitId, toUnitId])
}

model LocationItem {
  id           String        @id @default(cuid())
  locationId   String
  itemId       String
  parLevel     Decimal?      @db.Decimal(12, 2)
  visible      Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  location     Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([locationId, itemId])
}

model CountSession {
  id            String             @id @default(cuid())
  organizationId String
  locationId    String
  createdById   String
  sessionDate   DateTime
  status        CountSessionStatus @default(OPEN)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  location      Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdBy     User               @relation("CountSessionCreatedBy", fields: [createdById], references: [id])
  entries       CountEntry[]

  @@index([organizationId, locationId, status])
}

model CountEntry {
  id            String        @id @default(cuid())
  countSessionId String
  itemId        String
  quantity      Decimal       @db.Decimal(12, 2)
  notes         String?
  updatedAt     DateTime      @updatedAt
  createdAt     DateTime      @default(now())

  countSession  CountSession  @relation(fields: [countSessionId], references: [id], onDelete: Cascade)
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([countSessionId, itemId])
}

model ExternalMapping {
  id             String            @id @default(cuid())
  organizationId String
  itemId         String
  source         IntegrationSource
  externalId     String
  metadataJson   Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  item           InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([organizationId, source])
  @@unique([source, externalId])
}

model SyncJob {
  id             String            @id @default(cuid())
  organizationId String
  locationId     String?
  source         IntegrationSource
  status         JobStatus         @default(QUEUED)
  startedAt      DateTime?
  finishedAt     DateTime?
  errorMessage   String?
  payloadJson    Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, source, status])
}

model PilotCountSession {
  id           String          @id
  locationId   String
  locationName String
  status       CountSessionStatus @default(OPEN)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lines        PilotCountLine[]

  @@index([locationId, status])
}

model PilotCountLine {
  id        String           @id @default(cuid())
  sessionId String
  itemId    String
  name      String
  unit      String
  parLevel  Decimal          @db.Decimal(12, 2)
  quantity  Decimal          @db.Decimal(12, 2)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  session   PilotCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, itemId])
}

model PilotIntegrationItem {
  id             String            @id @default(cuid())
  source         IntegrationSource
  externalId     String
  name           String
  normalizedUnit String?
  syncedAt       DateTime          @default(now())

  @@unique([source, externalId])
  @@index([source, syncedAt])
}

model PilotItemMapping {
  id            String            @id @default(cuid())
  source        IntegrationSource
  externalId    String
  localItemId   String
  localItemName String
  confidence    Int               @default(100)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([source, externalId])
}

model PilotSyncRun {
  id            String            @id @default(cuid())
  source        IntegrationSource
  status        JobStatus
  startedAt     DateTime          @default(now())
  finishedAt    DateTime?
  importedCount Int?
  errorMessage  String?

  @@index([source, startedAt])
}
